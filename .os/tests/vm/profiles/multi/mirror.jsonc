// VM test: multi-disk OS mirror. 2 × 40 GiB → rpool (mirror), no storage pool.
{
  "name": "arch-zfs-test-multi-mirror",
  "hardware": { "disks": [40, 40], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-multi-mirror",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":      "lts",
      "bootloader":  "systemd-boot",
      "encryption":  false,
      "swap":        true,
      "swap_size":   "auto"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": {
      "backup": false,
      "security": false,
      "desktop": { "kde": false }
    },
    "mode": "multi",
    "os_pool": {
      "pool_name": "rpool",
      "topology":  "mirror",
      "ashift":    12,
      "disks":     ["/dev/sda", "/dev/sdb"]
    },
    "storage_groups": []
  }
}
