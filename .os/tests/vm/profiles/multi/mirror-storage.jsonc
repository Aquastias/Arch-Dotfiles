// VM test: OS mirror + storage mirror. 4 disks —
//   /dev/sda + /dev/sdb (40 GiB) → rpool (mirror)
//   /dev/sdc + /dev/sdd (20 GiB) → dpool/DATA/data (mirror)
{
  "name": "arch-zfs-test-multi-mirror-storage",
  "hardware": { "disks": [40, 40, 20, 20], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-multi-mirror-storage",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":      "lts",
      "bootloader":  "systemd-boot",
      "encryption":  false,
      "swap":        true,
      "swap_size":   "auto"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": {
      "backup": false,
      "security": false,
      "desktop": { "kde": false }
    },
    "mode": "multi",
    "os_pool": {
      "pool_name": "rpool",
      "topology":  "mirror",
      "ashift":    12,
      "disks":     ["/dev/sda", "/dev/sdb"]
    },
    "storage_groups": [
      {
        "name":     "data",
        "mount":    "/data",
        "ashift":   12,
        "topology": "mirror",
        "disks":    ["/dev/sdc", "/dev/sdd"]
      }
    ]
  }
}
