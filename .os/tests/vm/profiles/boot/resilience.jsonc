// VM test: boot-path resilience guards (ADR 0038). A plain single-disk
// systemd-boot install; the first-boot verifier composes the REAL hardened
// modules and asserts the guards fire — a critical ESP copy that cannot
// complete fails loudly while preserving the prior image, and a planted Stray
// Kernel is detected. The boot sentinel is emitted only when every guard
// passes, so a regression makes the host boot-verify time out (test fails).
{
  "name": "arch-zfs-test-boot-resilience",
  "hardware": { "disks": [40], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-resilience",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":     "lts",
      "bootloader": "systemd-boot",
      "encryption": false,
      "swap":       true,
      "swap_size":  "auto"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": { "backup": false, "security": false },
    "mode":              "single",
    "disk":              "/dev/sda",
    "ashift":            12,
    "os_size":           "32G",
    "os_pool_name":      "rpool",
    "storage_pool_name": "dpool",
    "storage_mount":     "/data",
    "storage_groups":    []
  },
  "verify": { "boot": true, "resilience": true }
}
