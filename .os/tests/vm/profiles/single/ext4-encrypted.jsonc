// VM test (ADR 0043, issue 04/slice 3): an encrypted ext4 root (LUKS).
// The non-guided harness presets INSTALL_ENC_PASSPHRASE='testtest', so the
// install runs unattended; the *boot* passphrase prompt is HITL (encrypted
// roots can't headless boot-verify) — run install-only (no --verify-boot) to
// confirm INSTALLER-EXIT-0, then boot the disk by hand and type `testtest`.
// Exercises: luksFormat/open the root, cryptsetup userland, encrypted
// ROOT_CMDLINE (cryptdevice=…:cryptroot) + HOOKS (encrypt), random-key swap via
// crypttab, and the FS-agnostic boot path.
{
  "name": "arch-zfs-test-single-ext4-enc",
  "hardware": { "disks": [40], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "filesystem": "ext4",
    "system": {
      "hostname": "vm-test-ext4-enc",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":     "lts",
      "bootloader": "systemd-boot",
      "encryption": true,
      "swap":       true,
      "swap_size":  "auto",
      "esp_size":   "1G"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": {
      "backup": false,
      "security": false,
      "desktop": { "kde": false }
    },
    "mode":           "single",
    "disk":           "/dev/sda",
    "storage_groups": []
  }
}
