// VM test (ADR 0043, issue 06): an encrypted xfs root (LUKS). Same shape as the
// encrypted ext4 root — the xfs leaf only swaps mkfs.xfs + the fstab fs-type;
// LUKS/cmdline/HOOKS/swap all come from the shared non-ZFS root spine. The
// non-guided harness presets INSTALL_ENC_PASSPHRASE='testtest', so the install
// runs unattended; the *boot* passphrase prompt is HITL (encrypted roots can't
// headless boot-verify) — run install-only (no --verify-boot) to confirm
// INSTALLER-EXIT-0, then boot the disk by hand and type `testtest`.
// Exercises: luksFormat/open the root, cryptsetup userland, encrypted
// ROOT_CMDLINE (cryptdevice=…:cryptroot) + HOOKS (encrypt), random-key swap via
// crypttab, and the FS-agnostic boot path.
{
  "name": "arch-zfs-test-single-xfs-enc",
  "hardware": { "disks": [40], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "filesystem": "xfs",
    "system": {
      "hostname": "vm-test-xfs-enc",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":     "lts",
      "bootloader": "systemd-boot",
      "encryption": true,
      "swap":       true,
      "swap_size":  "auto",
      "esp_size":   "1G"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": {
      "backup": false,
      "security": false,
      "desktop": { "kde": false }
    },
    "mode":           "single",
    "disk":           "/dev/sda",
    "storage_groups": []
  }
}
