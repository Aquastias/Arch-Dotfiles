// VM test: Standalone Data Pools end-to-end. 4 × 20 GiB —
//   /dev/sda → rpool (OS, topology=none, single disk)
//   /dev/sdb → tank0 (single-disk stripe)
//   /dev/sdc + /dev/sdd → tank1 (2-disk mirror)
// host_profile=arch-data (inside install) declares vm-data, so pool-owners
// gives the /data pools to that user. verify.boot runs the pool verifier; the
// sentinel fires only when every pool imported, every data dataset mounted,
// every leaf vdev resolves via by-id, and each pool is owned by vm-data.
{
  "name": "arch-zfs-test-multi-data-pools",
  "hardware": { "disks": [20, 20, 20, 20], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-multi-data-pools",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":      "lts",
      "bootloader":  "systemd-boot",
      "encryption":  false,
      "swap":        true,
      "swap_size":   "auto"
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": {
      "backup": false,
      "security": false,
      "desktop": { "kde": false }
    },
    "host_profile": "arch-data",
    "mode": "multi",
    "os_pool": {
      "pool_name": "rpool",
      "topology":  "none",
      "ashift":    12,
      "disks":     ["/dev/sda"]
    },
    "storage_groups": [],
    "data_pools": [
      { "name": "tank0", "topology": "stripe", "disks": ["/dev/sdb"] },
      { "name": "tank1", "topology": "mirror", "disks": ["/dev/sdc", "/dev/sdd"] }
    ]
  },
  "verify": {
    "boot":   true,
    "by_id":  true,
    "pools":  ["rpool", "tank0", "tank1"],
    "mounts": ["tank0/data:/data/tank0", "tank1/data:/data/tank1"],
    "owned":  ["/data/tank0:vm-data", "/data/tank1:vm-data"]
  }
}
