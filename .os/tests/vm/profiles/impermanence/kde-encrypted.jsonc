// VM test: impermanence + KDE + ZFS native encryption, single disk. Catches
// the regression where the Rollback Hook runs before the ZFS unlock hook.
// The installer prompts for the passphrase on /dev/tty — type it at the VM
// console when prompted (and again at every boot).
{
  "name": "arch-zfs-test-single-impermanent-kde-encrypted",
  "hardware": { "disks": [40], "ram_mb": 6144, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-imp-kde-enc",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":      "lts",
      "bootloader":  "systemd-boot",
      "encryption":  true,
      "swap":        true,
      "swap_size":   "auto",
      "impermanence": {
        "enabled": true,
        "dataset": "rpool/persist",
        "mount":   "/persist"
      }
    },
    "packages": { "extra": [], "groups": {} },
    "environment": { "desktop": "kde", "gpu": "auto" },
    "post_install": { "backup": false, "security": false },
    "mode":              "single",
    "disk":              "/dev/sda",
    "ashift":            12,
    "os_size":           "32G",
    "os_pool_name":      "rpool",
    "storage_pool_name": "dpool",
    "storage_mount":     "/data",
    "storage_groups":    []
  }
}
