// VM test: impermanence enabled, single disk. Rollback datasets revert to
// @blank on boot; /persist holds curated state.
{
  "name": "arch-zfs-test-single-impermanent",
  "hardware": { "disks": [40], "ram_mb": 4096, "vcpus": 2 },
  "install": {
    "system": {
      "hostname": "vm-test-imp",
      "locale":   "en_US.UTF-8",
      "timezone": "UTC",
      "keymap":   "us"
    },
    "options": {
      "kernel":      "lts",
      "bootloader":  "systemd-boot",
      "encryption":  false,
      "swap":        true,
      "swap_size":   "auto",
      "impermanence": {
        "enabled": true,
        "dataset": "rpool/persist",
        "mount":   "/persist"
      }
    },
    "packages": { "extra": [], "groups": {} },
    "post_install": { "backup": false, "security": false },
    "mode":              "single",
    "disk":              "/dev/sda",
    "ashift":            12,
    "os_size":           "32G",
    "os_pool_name":      "rpool",
    "storage_pool_name": "dpool",
    "storage_mount":     "/data",
    "storage_groups":    []
  }
}
