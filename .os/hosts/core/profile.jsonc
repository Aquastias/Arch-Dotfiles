// Host Core profile — base layer merged under every host profile.jsonc
// (ADR 0036). Defines the shared software base: users, System Programs,
// and Sysctl Defaults (per ADR 0007 — never a package list). Lists
// concat+dedupe with the host profile; scalars host-wins.
{
  "users": [],
  "system_programs": ["cups"],
  "sysctl": {
    "vm.swappiness": 10
  }
}
